{{define "base"}}
<!DOCTYPE html>
<html lang="{{.Lang}}">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<meta name="description" content="Generate docker-compose and .env for Stargate, Warden, Herald.">
	<meta name="author" content="Stargate Suite">
	<title>{{.Title}}</title>
	<link rel="preconnect" href="https://cdn.jsdelivr.net">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
	<link rel="preload" href="/static/css/style.css" as="style">
	<link rel="stylesheet" href="/static/css/style.css">
</head>
<body>
	<div class="container py-3">
		<header>
			<div class="d-flex flex-column flex-md-row align-items-center pb-3 mb-4 border-bottom">
				<a href="/" class="d-flex align-items-center link-body-emphasis text-decoration-none">
					<svg xmlns="http://www.w3.org/2000/svg" width="40" height="32" class="me-2" viewBox="0 0 118 94" role="img" aria-hidden="true">
						<path fill-rule="evenodd" clip-rule="evenodd" d="M24.509 0c-6.733 0-11.715 5.893-11.492 12.284.214 6.14-.064 14.092-2.066 20.577C8.943 39.365 5.547 43.485 0 44.014v5.972c5.547.529 8.943 4.649 10.951 11.153 2.002 6.485 2.28 14.437 2.066 20.577C12.794 88.106 17.776 94 24.51 94H93.5c6.733 0 11.714-5.893 11.491-12.284-.214-6.14.064-14.092 2.066-20.577 2.009-6.504 5.396-10.624 10.943-11.153v-5.972c-5.547-.529-8.934-4.649-10.943-11.153-2.002-6.484-2.28-14.437-2.066-20.577C105.214 5.894 100.233 0 93.5 0H24.508zM80 57.863C80 66.663 73.436 72 62.543 72H44a2 2 0 01-2-2V24a2 2 0 012-2h18.437c9.083 0 15.044 4.92 15.044 12.474 0 5.302-4.01 10.049-9.119 10.88v.277C75.317 46.394 80 51.21 80 57.863zM60.521 28.34H49.948v14.934h8.905c6.884 0 10.68-2.772 10.68-7.727 0-4.643-3.264-7.207-9.012-7.207zM49.948 49.2v16.458H60.91c7.167 0 10.964-2.876 10.964-8.281 0-5.406-3.903-8.178-11.425-8.178H49.948z" fill="currentColor"></path>
					</svg>
					<span class="fs-4" data-i18n="title">{{.Title}}</span>
				</a>
				<nav class="d-inline-flex mt-2 mt-md-0 ms-md-auto align-items-center gap-2">
					<a class="py-2 link-body-emphasis text-decoration-none" href="/keys" data-i18n="keysTitle">密钥与 API Key</a>
					<a class="py-2 link-body-emphasis text-decoration-none" href="/import" data-i18n="choiceImport">导入配置</a>
					<span class="lang-switch ms-2">
						<a href="#" class="btn btn-link p-0 lang-link" data-lang="zh" id="lang-zh">中文</a>
						<span class="text-muted">/</span>
						<a href="#" class="btn btn-link p-0 lang-link" data-lang="en" id="lang-en">English</a>
					</span>
				</nav>
			</div>
			<div class="pricing-header p-3 pb-md-4 mx-auto text-center">
				<p class="fs-5 text-body-secondary mb-0" data-i18n="subtitle">Select a scenario preset and options, then click Generate.</p>
			</div>
		</header>

		<main>
			<div class="row">
				<div class="col-12">
					{{if eq .Page "entry"}}{{template "content-entry" .}}{{end}}{{if eq .Page "wizard-1"}}{{template "content-wizard-1" .}}{{end}}{{if eq .Page "wizard-2"}}{{template "content-wizard-2" .}}{{end}}{{if eq .Page "wizard-3"}}{{template "content-wizard-3" .}}{{end}}{{if eq .Page "wizard-4"}}{{template "content-wizard-4" .}}{{end}}{{if eq .Page "wizard-5"}}{{template "content-wizard-5" .}}{{end}}{{if eq .Page "keys"}}{{template "content-keys" .}}{{end}}{{if eq .Page "import"}}{{template "content-import" .}}{{end}}{{if eq .Page "review"}}{{template "content-review" .}}{{end}}{{if not .Page}}{{template "content-entry" .}}{{end}}
				</div>
			</div>
		</main>

		<footer class="pt-4 my-md-5 pt-md-5 border-top">
			
		</footer>
	</div>

	<script>window.I18N = {{.I18N}};</script>
	<script>window.SCENARIOS = {{.Scenarios}};</script>
	<script src="/static/js/bootstrap.bundle.min.js"></script>
	<script src="/static/js/app.js" defer></script>
</body>
</html>
{{end}}
