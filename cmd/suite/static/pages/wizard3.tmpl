{{define "content-wizard-3"}}
<div class="main-view main-view-wizard">
	<div class="wizard-toolbar mb-4">
		<a href="/" class="btn btn-link text-body-secondary px-0" data-i18n="backToChoice">← 返回选择</a>
	</div>
	<nav class="step-nav step-nav-labeled mb-4" aria-label="Configuration steps">
		<a href="/wizard/step-1" class="step-nav-item"><span class="step-num">1</span><span class="step-label" data-i18n="step1ComposeTypeShort">场景预设</span></a>
		<a href="/wizard/step-2" class="step-nav-item"><span class="step-num">2</span><span class="step-label" data-i18n="step2GeneralOptionsShort">通用</span></a>
		<a href="/wizard/step-3" class="step-nav-item active"><span class="step-num">3</span><span class="step-label" data-i18n="step3StargateShort">Stargate</span></a>
		<a href="/wizard/step-4" class="step-nav-item"><span class="step-num">4</span><span class="step-label" data-i18n="step4WardenShort">Warden</span></a>
		<a href="/wizard/step-5" class="step-nav-item"><span class="step-num">5</span><span class="step-label" data-i18n="step5HeraldShort">Herald</span></a>
		<a href="/review" class="step-nav-item"><span class="step-num">6</span><span class="step-label" data-i18n="step6ReviewShort">确认生成</span></a>
	</nav>
	<form id="form-step-3" class="form wizard-form" method="post" action="/wizard/step-3">
		<section class="config-step-block" data-step="3">
			<h2 class="step-heading mb-2" data-i18n="step3Stargate">3. Stargate（门 - Forward Auth）</h2>
			<p class="step-desc text-body-secondary mb-4" data-i18n="step3StargateDesc">鉴权、登录编排、会话与下游 Header。</p>
			<fieldset class="field-group config-options-cols border-0 p-0">
				{{range .Services}}{{if eq .Id "stargate"}}{{$s := .}}
				{{range $s.Sections}}
				<div class="env-group mb-4" data-section-key="{{.TitleKey}}">
					{{if .TitleKey}}<h3 class="section-title h6 mb-3" data-i18n="{{.TitleKey}}"></h3>{{end}}
					{{range .EnvVars}}
					<div class="config-item mb-3" data-env-name="{{.Env}}"{{if .ShowWhenEnv}} data-depends-on-env="{{.ShowWhenEnv}}"{{end}}{{if .ShowWhenOption}} data-depends-on-option="{{.ShowWhenOption}}"{{end}}>
						{{if eq .Type "checkbox"}}
						<div class="form-check">
							<input type="hidden" name="{{.Env}}" value="false">
							<input type="checkbox" name="{{.Env}}" id="env_{{.Env}}_{{$s.Id}}" data-env="{{.Env}}" class="form-check-input" value="true"{{if .Default}} checked{{end}}>
							<label class="form-check-label" for="env_{{.Env}}_{{$s.Id}}"><span data-i18n="{{.LabelKey}}"></span> <code class="config-env">{{.Env}}</code></label>
						</div>
						{{else}}
						<label for="env_{{.Env}}_{{$s.Id}}" class="form-label"><span data-i18n="{{.LabelKey}}"></span> <code class="config-env">{{.Env}}</code></label>
						{{if eq .Type "text"}}
						<input type="text" name="{{.Env}}" id="env_{{.Env}}_{{$s.Id}}" data-env="{{.Env}}" class="form-control"{{if .Placeholder}} placeholder="{{.Placeholder}}"{{end}}{{if .Default}} value="{{.Default}}"{{end}}>
						{{else if eq .Type "number"}}
						<input type="number" name="{{.Env}}" id="env_{{.Env}}_{{$s.Id}}" data-env="{{.Env}}" class="form-control"{{if .Placeholder}} placeholder="{{.Placeholder}}"{{end}}{{if .Default}} value="{{.Default}}"{{end}}{{if .Min}} min="{{.Min}}"{{end}}{{if .Max}} max="{{.Max}}"{{end}}>
						{{else if eq .Type "select"}}
						<select name="{{.Env}}" id="env_{{.Env}}_{{$s.Id}}" data-env="{{.Env}}" class="form-select">
							{{$def := .Default}}{{range .Options}}
							<option value="{{.Value}}"{{if eq (printf "%v" $def) .Value}} selected{{end}}>{{.Value}}</option>
							{{end}}
						</select>
						{{end}}
						{{end}}
						<p class="form-text small mb-0 mt-1" data-i18n="{{.DescKey}}"></p>
					</div>
					{{end}}
				</div>
				{{end}}
				{{end}}{{end}}
			</fieldset>
			<div class="step-actions pt-2">
				<a href="/wizard/step-2" class="btn btn-outline-secondary" data-i18n="stepPrev">上一步</a>
				<button type="submit" class="btn btn-primary btn-lg" data-i18n="stepNext">下一步</button>
			</div>
		</section>
	</form>
</div>
{{end}}
