{{define "content-wizard-1"}}
<div class="main-view main-view-wizard">
	<div class="wizard-toolbar mb-4">
		<a href="/" class="btn btn-link text-body-secondary px-0" data-i18n="backToChoice">← 返回选择</a>
	</div>
	<nav class="step-nav step-nav-labeled mb-4" aria-label="Configuration steps">
		<a href="/wizard/step-1" class="step-nav-item active"><span class="step-num">1</span><span class="step-label" data-i18n="step1ComposeTypeShort">场景预设</span></a>
		<a href="/wizard/step-2" class="step-nav-item"><span class="step-num">2</span><span class="step-label" data-i18n="step2GeneralOptionsShort">通用</span></a>
		<a href="/wizard/step-3" class="step-nav-item"><span class="step-num">3</span><span class="step-label" data-i18n="step3StargateShort">Stargate</span></a>
		<a href="/wizard/step-4" class="step-nav-item"><span class="step-num">4</span><span class="step-label" data-i18n="step4WardenShort">Warden</span></a>
		<a href="/wizard/step-5" class="step-nav-item"><span class="step-num">5</span><span class="step-label" data-i18n="step5HeraldShort">Herald</span></a>
		<a href="/review" class="step-nav-item"><span class="step-num">6</span><span class="step-label" data-i18n="step6ReviewShort">确认生成</span></a>
	</nav>
	<form id="form-step-1" class="form wizard-form" method="post" action="/wizard/step-1">
		<section class="config-step-block" data-step="1">
			<h2 class="step-heading mb-2" data-i18n="step1ComposeType">1. 选择场景预设</h2>
			<p class="step-desc text-body-secondary mb-4" data-i18n="step1ComposeTypeDesc">选择场景预设以自动应用推荐配置。</p>
			<div class="config-item mb-4">
				<span class="form-label d-block mb-2" data-i18n="scenarioPresetLabel">场景预设</span>
				<div id="scenario-list-group" class="list-group list-group-radio d-grid gap-2 border-0">
					<div class="position-relative">
						<input class="form-check-input position-absolute top-50 end-0 me-3 fs-5" type="radio" name="scenario" id="scenario-radio-empty" value="" checked="">
						<label class="list-group-item py-3 pe-5" for="scenario-radio-empty">
							<strong class="fw-semibold" data-i18n="scenarioPresetPlaceholder">手动选择（不使用预设）</strong>
							<span class="d-block small text-body-secondary mt-1" data-i18n="scenarioPresetDesc">选择预设后会自动填充配置选项和环境变量，可继续手动调整。</span>
						</label>
					</div>
					<div id="scenario-list-options"></div>
				</div>
				<p class="form-text mt-2 mb-0" id="scenario-desc" data-i18n="scenarioPresetDesc">选择预设后会自动填充配置选项和环境变量，可继续手动调整。</p>
				<p class="form-text text-warning mt-2 mb-0" id="scenario-risk" style="display:none;"></p>
			</div>
			<div id="scenario-mode-inputs"></div>
			<div class="step-actions pt-2">
				<button type="submit" class="btn btn-primary btn-lg" data-i18n="stepNext">下一步</button>
			</div>
		</section>
	</form>
</div>
{{end}}
